# API URL for backend
# For local development, leave empty or use '/api' (uses Vite proxy)
# For production, use your deployed backend URL

# Local Development (uses Vite proxy):
VITE_API_URL=

# Production Example:
# VITE_API_URL=https://alirwanda-server.onrender.com/api

# Google OAuth
# Get your Google Client ID from: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
