# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/alirwanda
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/alirwanda?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=alirwanda_secret_key_2024_super_secure_CHANGE_IN_PRODUCTION
JWT_EXPIRE=7d

# CORS Configuration
FRONTEND_URL=http://localhost:3000
# For production:
# FRONTEND_URL=https://alirwanda.onrender.com

# Security (Optional)
# BCRYPT_ROUNDS=10
# RATE_LIMIT_WINDOW=15
# RATE_LIMIT_MAX=100

# Google OAuth Configuration
# Get your Google Client ID and Secret from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
